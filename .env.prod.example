# my-chat 生产环境变量样板
# 使用：cp .env.prod.example .env 并修改下方占位

# ----- 容器对外端口（默认 8091，避免与 calorie-log 的 8088 冲突） -----
WEB_PORT=8091

# ----- 必填：模型 API 密钥（yun-apis） -----
YUN_API_KEY=sk-REPLACE_ME_WITH_YOUR_KEY
YUN_API_BASE=https://api.yun-apis.com/v1
CHAT_MODEL=gpt-5.5
IMAGE_MODEL=gpt-image-2

# ----- 必填：会话签名密钥（>= 32 字符） -----
# 生成：openssl rand -base64 48 | tr -d '\n'
SESSION_SECRET=REPLACE_ME_SESSION_SECRET_AT_LEAST_32_CHARS_xxxxxxxxxxxx
